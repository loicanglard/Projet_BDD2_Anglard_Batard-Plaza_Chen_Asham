<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.artconnect.ui.WorkshopController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>

    <HBox spacing="8.0" alignment="CENTER_LEFT">
        <Button text="➕ Ajouter"   onAction="#handleAdd"    style="-fx-base: #4CAF50; -fx-text-fill: white;" />
        <Button text="✏️ Modifier"  onAction="#handleEdit"   style="-fx-base: #2196F3; -fx-text-fill: white;" />
        <Button text="🗑️ Supprimer" onAction="#handleDelete" style="-fx-base: #F44336; -fx-text-fill: white;" />
    </HBox>

    <TableView fx:id="workshopTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="titleColumn"      text="Titre"       prefWidth="200" />
            <TableColumn fx:id="instructorColumn" text="Instructeur"  prefWidth="160" />
            <TableColumn fx:id="dateColumn"       text="Date"         prefWidth="150" />
            <TableColumn fx:id="priceColumn"      text="Prix €"       prefWidth="80" />
            <TableColumn fx:id="levelColumn"      text="Niveau"       prefWidth="100" />
        </columns>
        <placeholder><Label text="Aucun atelier trouvé." /></placeholder>
    </TableView>
</VBox>
